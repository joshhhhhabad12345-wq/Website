    lbl.Position               = UDim2.new(0, 10, 0, 4)
    lbl.BackgroundTransparency = 1
    lbl.Font                   = Enum.Font.Gotham
    lbl.Text                   = "Crosshair Image ID"
    lbl.TextColor3             = Color3.fromRGB(210, 210, 210)
    lbl.TextSize               = 11
    lbl.TextXAlignment         = Enum.TextXAlignment.Left

    local box = Instance.new("TextBox", wrap)
    box.Size                  = UDim2.new(1, -20, 0, 18)
    box.Position              = UDim2.new(0, 10, 0, 22)
    box.BackgroundColor3      = Color3.fromRGB(36, 36, 36)
    box.BorderSizePixel       = 0
    box.Font                  = Enum.Font.Gotham
    box.Text                  = ""
    box.PlaceholderText       = "rbxassetid://...  (blank = default +)"
    box.PlaceholderColor3     = Color3.fromRGB(90, 90, 90)
    box.TextColor3            = Color3.fromRGB(230, 230, 230)
    box.TextSize              = 10
    box.TextXAlignment        = Enum.TextXAlignment.Left
    box.ClearTextOnFocus      = false
    box.ZIndex                = 10
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    local boxPad = Instance.new("UIPadding", box)
    boxPad.PaddingLeft = UDim.new(0, 4)

    box.FocusLost:Connect(function()
        local raw = box.Text:match("^%s*(.-)%s*$")
        if raw == "" then
            Settings.CrosshairImageId = ""
        elseif raw:match("^%d+$") then
            Settings.CrosshairImageId = "rbxassetid://" .. raw
        else
            Settings.CrosshairImageId = raw
        end
    end)
    return wrap
end

