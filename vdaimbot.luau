    knob.BorderSizePixel  = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local state = defaultOn
    local ti    = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    local function SetState(on, fireCallback)
        state = on
        TweenService:Create(track, ti, {BackgroundColor3 = on and Color3.fromRGB(255,255,255) or Color3.fromRGB(60,60,60)}):Play()
        TweenService:Create(knob,  ti, {Position         = on and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)}):Play()
        TweenService:Create(knob,  ti, {BackgroundColor3 = on and Color3.fromRGB(20,20,20) or Color3.fromRGB(200,200,200)}):Play()
