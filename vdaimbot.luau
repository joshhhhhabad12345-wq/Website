    lbl.BackgroundTransparency = 1
    lbl.Font                   = Enum.Font.Gotham
    lbl.Text                   = labelText
    lbl.TextColor3             = Color3.fromRGB(210, 210, 210)
    lbl.TextSize               = 11
    lbl.TextXAlignment         = Enum.TextXAlignment.Left

    local list = Instance.new("Frame", wrap)
    list.Size                   = UDim2.new(1, -20, 0, 22)
    list.Position               = UDim2.new(0, 10, 0, 24)
    list.BackgroundTransparency = 1

    local rowLayout = Instance.new("UIListLayout", list)
    rowLayout.FillDirection = Enum.FillDirection.Horizontal
    rowLayout.Padding       = UDim.new(0, 6)
    rowLayout.SortOrder     = Enum.SortOrder.LayoutOrder

    local selectedStroke = nil
    for i, col in ipairs(COLORS) do
        local sw = Instance.new("TextButton", list)
        sw.LayoutOrder      = i
        sw.Size             = UDim2.new(0, 22, 0, 22)
        sw.BackgroundColor3 = col
        sw.BorderSizePixel  = 0
        sw.Text             = ""
        Instance.new("UICorner", sw).CornerRadius = UDim.new(1, 0)

        local stroke = Instance.new("UIStroke", sw)
        stroke.Color        = Color3.fromRGB(255, 255, 255)
        stroke.Thickness    = 0
        stroke.Transparency = 1

        local function Pick()
            if selectedStroke then
                TweenService:Create(selectedStroke, TweenInfo.new(0.15), {Thickness = 0, Transparency = 1}):Play()
            end
            TweenService:Create(stroke, TweenInfo.new(0.15), {Thickness = 2, Transparency = 0}):Play()
            selectedStroke = stroke
            callback(col)
        end

        sw.MouseButton1Click:Connect(Pick)
        sw.MouseEnter:Connect(function()
            TweenService:Create(sw, TweenInfo.new(0.12), {Size = UDim2.new(0,25,0,25)}):Play()
        end)
        sw.MouseLeave:Connect(function()
            TweenService:Create(sw, TweenInfo.new(0.12), {Size = UDim2.new(0,22,0,22)}):Play()
        end)
    end
    return wrap
end

