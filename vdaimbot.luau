--  Crosshair  ("+" Drawing or Image)
-- ──────────────────────────────────────────────
local CrosshairLines = {}
for i = 1, 4 do
    local line = Drawing.new("Line")
    line.Visible   = false
    line.Color     = Settings.CrosshairColor
    line.Thickness = Settings.CrosshairThickness
    CrosshairLines[i] = line
end

local CrosshairImage = Instance.new("ImageLabel", ScreenGui)
CrosshairImage.Name                  = "CrosshairImage"
CrosshairImage.BackgroundTransparency = 1
CrosshairImage.AnchorPoint           = Vector2.new(0.5, 0.5)
CrosshairImage.Position              = UDim2.new(0.5, 0, 0.5, 0)
CrosshairImage.Size                  = UDim2.new(0, 32, 0, 32)
CrosshairImage.Image                 = Settings.CrosshairImageId
CrosshairImage.ImageColor3           = Settings.CrosshairColor
CrosshairImage.Visible               = false
CrosshairImage.ZIndex                = 20

local function UpdateCrosshair()
    local center     = ScreenCenter()
    local s          = Settings.CrosshairSize
    local usingImage = Settings.CrosshairImageId ~= ""

    CrosshairImage.Image       = Settings.CrosshairImageId
    CrosshairImage.ImageColor3 = Settings.CrosshairColor
    CrosshairImage.Visible     = Settings.CrosshairVisible and usingImage
    CrosshairImage.Size        = UDim2.new(0, s * 2, 0, s * 2)

    local showLines = Settings.CrosshairVisible and not usingImage
    -- left
    CrosshairLines[1].From     = Vector2.new(center.X - s, center.Y)
    CrosshairLines[1].To       = Vector2.new(center.X - 4, center.Y)
    CrosshairLines[1].Color    = Settings.CrosshairColor
    CrosshairLines[1].Thickness = Settings.CrosshairThickness
    CrosshairLines[1].Visible  = showLines
    -- right
    CrosshairLines[2].From     = Vector2.new(center.X + 4, center.Y)
    CrosshairLines[2].To       = Vector2.new(center.X + s, center.Y)
    CrosshairLines[2].Color    = Settings.CrosshairColor
    CrosshairLines[2].Thickness = Settings.CrosshairThickness
    CrosshairLines[2].Visible  = showLines
    -- up
    CrosshairLines[3].From     = Vector2.new(center.X, center.Y - s)
    CrosshairLines[3].To       = Vector2.new(center.X, center.Y - 4)
    CrosshairLines[3].Color    = Settings.CrosshairColor
    CrosshairLines[3].Thickness = Settings.CrosshairThickness
    CrosshairLines[3].Visible  = showLines
    -- down
    CrosshairLines[4].From     = Vector2.new(center.X, center.Y + 4)
    CrosshairLines[4].To       = Vector2.new(center.X, center.Y + s)
    CrosshairLines[4].Color    = Settings.CrosshairColor
    CrosshairLines[4].Thickness = Settings.CrosshairThickness
    CrosshairLines[4].Visible  = showLines
end

RunService.RenderStepped:Connect(UpdateCrosshair)

